# ===== Secrets (API keys, signing keys) — never commit =====
tool/secrets.env
*.env
# 上架簽章金鑰整個資料夾一律不進版控（比只擋 *.jks 更保險）
/keystore/

# ===== Claude Code (local session settings) =====
.claude/settings.local.json

# ===== Local run / debug artifacts =====
.run_log.txt
.run_debug*.txt

# ===== Miscellaneous =====
*.class
*.log
*.pyc
__pycache__/
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ===== Python（tool/ 內的素材/語音/音效產生器）=====
.venv/
venv/
tool/venv/
tool/.venv/
*.egg-info/
.pytest_cache/
